{
    "name": "achttienvijftien/wp-content-importer",
    "description": "Import CSV/XLS content into WordPress",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "homepage": "https://www.1815.nl",
    "authors": [
        {
            "name": "1815",
            "email": "it@1815.nl",
            "homepage": "https://www.1815.nl"
        }
    ],
    "require": {
        "php": "^8.4",
        "composer/installers": "^1.8",
        "phpoffice/phpspreadsheet": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "yoast/phpunit-polyfills": "^3.0",
        "wp-phpunit/wp-phpunit": "^6.7",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "achttienvijftien/building-techniques": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "AchttienVijftien\\WpContentImporter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AchttienVijftien\\WpContentImporter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "format": "phpcbf --report-summary --report-source",
        "lint": "phpcs",
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
